# Slack bot token used by gateway Slack adapter
SLACK_BOT_TOKEN=xoxb-your-slack-token

# Slack signing secret used to validate Slack events
SLACK_SIGNING_SECRET=replace-with-signing-secret

# Microsoft Teams bot app id used by botbuilder adapter
TEAMS_APP_ID=00000000-0000-0000-0000-000000000000

# Microsoft Teams bot app password used by botbuilder adapter
TEAMS_APP_PASSWORD=replace-with-teams-password

# Base URL for Python rewrite pipeline service
PIPELINE_URL=http://pipeline:8000

# Fastify gateway port
PORT=3000

# Python pipeline port
PIPELINE_PORT=8000

# Default LLM provider key: openai, anthropic, gemini, openrouter
DEFAULT_PROVIDER=openai

# OpenAI provider key
OPENAI_API_KEY=replace-with-openai-key

# Anthropic provider key
ANTHROPIC_API_KEY=replace-with-anthropic-key

# Gemini provider key
GEMINI_API_KEY=replace-with-gemini-key

# OpenRouter provider key
OPENROUTER_API_KEY=replace-with-openrouter-key
